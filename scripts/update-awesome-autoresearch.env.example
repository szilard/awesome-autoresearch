# Copy this file to scripts/update-awesome-autoresearch.env and fill in your secrets.
# The updater script sources this file automatically when present.

# Example: Anthropic API key
# export ANTHROPIC_API_KEY="sk-ant-..."

# Optional: force a specific pi binary
# export PI_BIN="/absolute/path/to/pi"

# Optional: if launchd cannot resolve pi, point directly to node + cli.js
# export NODE_BIN="/absolute/path/to/node"
# export PI_CLI_JS="/absolute/path/to/pi-coding-agent/dist/cli.js"
